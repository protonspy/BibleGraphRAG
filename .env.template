# OpenRouter (OpenAI-compatible)
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Models (OpenAI via OpenRouter)
LLM_MODEL=openai/gpt-4o
LLM_SMALL_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-small

# Deep researcher — own model for the LangGraph orchestration (plan / distil / synthesize).
# RESEARCH_SMALL_MODEL is optional; it falls back to RESEARCH_MODEL when unset.
RESEARCH_MODEL=deepseek/deepseek-v4-flash
# RESEARCH_SMALL_MODEL=deepseek/deepseek-v4-flash

# OpenAlex — the researcher's scholarly source (free, keyless). Set a contact email to opt into the
# faster "polite pool". OPENALEX_PER_PAGE caps works fetched per sub-query.
# OPENALEX_MAILTO=you@example.com
# OPENALEX_PER_PAGE=5

# Full-text reader for the deep-read tier — browser-emulating proxy that returns clean text (handles
# bot walls, landing pages, PDF/OCR). Jina Reader's keyless endpoint is the default; empty disables it.
# READER_SERVICE_URL=https://r.jina.ai/